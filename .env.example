# Application
TASKA_APP_NAME=Taska
TASKA_DEBUG=true
TASKA_SECRET_KEY=change-me-in-production
TASKA_BASE_URL=http://localhost:8000

# Database
TASKA_DATABASE_URL=sqlite:///./taska.db

# GitHub OAuth (https://github.com/settings/developers)
TASKA_GITHUB_CLIENT_ID=
TASKA_GITHUB_CLIENT_SECRET=

# Telegram Login (создайте бота через @BotFather, /setdomain для домена)
TASKA_TELEGRAM_BOT_TOKEN=
TASKA_TELEGRAM_BOT_USERNAME=
